{
  "name": "trips",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n convex,vite -c blue,green \"bun run dev:convex\" \"bun run dev:vite\"",
    "dev:vite": "vite",
    "dev:convex": "convex dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "bun run build && wrangler pages deploy dist --project-name=trips"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "@clerk/clerk-react": "^5.61.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@liveblocks/client": "^3.18.0",
    "@liveblocks/react": "^3.18.0",
    "@mapbox/mapbox-gl-geocoder": "^5.1.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/router-devtools": "^1.166.11",
    "@tanstack/router-plugin": "^1.167.12",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "convex": "^1.34.1",
    "mapbox-gl": "^3.21.0",
    "marked": "^18.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.8.1",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/mapbox-gl": "^3.5.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wrangler": "^4.81.0"
